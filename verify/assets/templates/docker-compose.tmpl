  #   ports:
  #     - "8080:8080"
  #   environment:
  #     - DATABASE_URL=postgresql://app:dev@postgres:5432/appdb
  #     - REDIS_URL=redis://redis:6379
  #     - OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
  #     - OTEL_SERVICE_NAME=app-service
  #   depends_on:
  #     postgres:
  #       condition: service_healthy
  #     redis:
  #       condition: service_healthy
  #   healthcheck:
  #     test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
  #     interval: 10s
  #     timeout: 5s
  #     retries: 3
  #   networks:
  #     - verify-net

  # ── Infrastructure Services ───────────────────────────────────────────
  # Databases, caches, message queues from IMPL-CODE external_dependencies.

  # postgres:
  #   image: postgres:16
  #   environment:
  #     POSTGRES_DB: appdb
  #     POSTGRES_USER: app
  #     POSTGRES_PASSWORD: dev
  #   ports:
  #     - "5432:5432"
  #   healthcheck:
  #     test: ["CMD-SHELL", "pg_isready -U app -d appdb"]
  #     interval: 5s
  #     timeout: 3s
  #     retries: 5
  #   networks:
  #     - verify-net

  # redis:
  #   image: redis:7-alpine
  #   ports:
  #     - "6379:6379"
  #   healthcheck:
  #     test: ["CMD", "redis-cli", "ping"]
  #     interval: 5s
  #     timeout: 3s
  #     retries: 5
  #   networks:
  #     - verify-net

  # ── Observability Stack ───────────────────────────────────────────────
  # Prometheus + Grafana (light mode), + Loki + Tempo (heavy mode).
  # Config files provisioned from DEVOPS-OBS artifacts.

  prometheus:
    image: prom/prometheus:latest
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./monitoring/alerts.yml:/etc/prometheus/alerts.yml:ro
    ports:
      - "9090:9090"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--web.enable-lifecycle"
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:9090/-/healthy"]
      interval: 10s
      timeout: 5s
      retries: 3
    networks:
      - verify-net

  grafana:
    image: grafana/grafana:latest
    volumes:
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./monitoring/dashboards:/var/lib/grafana/dashboards:ro
    environment:
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: Admin
      GF_SECURITY_ADMIN_PASSWORD: admin
    ports:
      - "3000:3000"
    depends_on:
      prometheus:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"]
      interval: 10s
      timeout: 5s
      retries: 3
    networks:
      - verify-net

  # ── Heavy mode only ──────────────────────────────────────────────────

