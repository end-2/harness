  #     interval: 10s
  #     timeout: 5s
  #     retries: 3
  #   networks:
  #     - verify-net

  # tempo:
  #   image: grafana/tempo:latest
  #   volumes:
  #     - ./monitoring/tempo-config.yml:/etc/tempo/config.yaml:ro
  #   ports:
  #     - "3200:3200"   # Tempo UI
  #     - "4317:4317"   # OTLP gRPC
  #     - "4318:4318"   # OTLP HTTP
  #   command: -config.file=/etc/tempo/config.yaml
