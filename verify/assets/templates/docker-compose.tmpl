# Docker Compose template for Verify local integration environment.
# This is a skeleton — the provision stage populates it from Impl and DevOps artifacts.
#
# Structure:
#   1. Application services (from IMPL-MAP component_ref → ARCH-COMP type)
#   2. Infrastructure services (from IMPL-CODE external_dependencies)
#   3. Observability stack (from DEVOPS-OBS observability_config)
#
# Usage:
#   docker compose -f docker-compose.verify.yml up -d
#   docker compose -f docker-compose.verify.yml down -v

version: "3.8"

services:
  # ── Application Services ──────────────────────────────────────────────
  # One service per ARCH-COMP with type=service, built from IMPL source.

  # app-service:
  #   build:
  #     context: .
